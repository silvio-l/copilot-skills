# Copy to homeassistant/local-secrets.env and keep that file ignored.
# Store only real secrets here; keep structured non-secret context in local-config.yaml/json.

HA_URL=http://YOUR_HA_HOST:8123
HA_TOKEN=
HA_SSH_HOST=YOUR_HA_HOST
HA_SSH_USER=YOUR_SSH_USER
HA_SSH_PASSWORD=
MQTT_USERNAME=
MQTT_PASSWORD=
OPENAI_API_KEY=
